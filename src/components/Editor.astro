---
---

<section class="flex-1 flex flex-col bg-[#080808]">
  <!-- Toolbar -->
  <div class="h-12 border-b border-white/5 flex items-center px-4 justify-between bg-black/40">
    <div class="flex items-center gap-4">
      <span class="text-[10px] font-bold uppercase tracking-widest text-white/40">EDITOR DE DIAPOSITIVAS</span>
      <div class="h-4 w-[1px] bg-white/10"></div>
      <div id="editor-info" class="text-[10px] font-medium text-white/60">
        Ninguna diapositiva seleccionada
      </div>
    </div>

  </div>

  <!-- Content Editor -->
  <div class="flex-1 p-8 flex items-center justify-center relative overflow-hidden group">
    <!-- Background Preview -->
    <div id="editor-bg" class="absolute inset-0 z-0 opacity-20 bg-cover bg-center transition-all duration-700"></div>
    <div class="absolute inset-0 z-10 bg-gradient-to-t from-black via-transparent to-black/60"></div>

    <!-- WYSIWYG Slide Content -->
    <div 
      id="editor-content"
      contenteditable="true" 
      class="relative z-20 w-full max-w-2xl min-h-[200px] flex items-center justify-center text-center text-4xl font-bold tracking-tight outline-none focus:ring-2 focus:ring-brand-cyan/20 p-8 rounded-xl transition-all empty:before:content-['Haz_clic_en_una_diapositiva_para_editar...'] empty:before:text-white/20 empty:before:italic"
    ></div>

  </div>
</section>

<script>
    import { songManager } from '../utils/songManager';
    import { projectionManager } from '../utils/projectionManager';

    const editorContent = document.getElementById('editor-content');
    const editorBg = document.getElementById('editor-bg') as HTMLElement;
    const editorInfo = document.getElementById('editor-info');
    const saveBtn = document.getElementById('editor-save');
    const projectBtn = document.getElementById('editor-project');

    let currentSong = null;
    let currentSlideIndex = -1;

    projectBtn?.addEventListener('click', () => {
        if (currentSlideIndex !== -1) {
            projectionManager.updateSlide(currentSlideIndex);
        }
    });

    // Listen for song selection to set initially
    window.addEventListener('takiy_song_selected', (e: any) => {
        currentSong = e.detail;
        currentSlideIndex = 0;
        updateEditor();
    });

    // Listen for slide change in queue to update editor
    window.addEventListener('hb_slide_changed', (e: any) => {
        currentSlideIndex = e.detail.index;
        // We need the queue data which is usually handled in Queue.astro
        // For simplicity, let's assume we can find the current slide text from the selected song
        updateEditor();
    });

    function updateEditor() {
        if (!currentSong || currentSlideIndex === -1) return;
        
        const slide = currentSong.slides[currentSlideIndex];
        if (editorContent) editorContent.innerHTML = slide.text;
        if (editorBg) editorBg.style.backgroundImage = `url(${currentSong.background})`;
        if (editorInfo) editorInfo.innerText = `${currentSong.title} - Diapositiva ${(currentSlideIndex + 1)}`;
    }

    saveBtn?.addEventListener('click', () => {
        if (!currentSong || currentSlideIndex === -1) return;
        
        // Save content
        const newText = editorContent?.innerHTML || '';
        currentSong.slides[currentSlideIndex].text = newText;
        
        songManager.saveSong(currentSong);
        
        // Visual feedback
        const originalText = saveBtn.innerText;
        saveBtn.innerText = '¡GUARDADO!';
        saveBtn.classList.replace('text-brand-magenta', 'text-green-500');
        
        setTimeout(() => {
            saveBtn.innerText = originalText;
            saveBtn.classList.replace('text-green-500', 'text-brand-magenta');
        }, 2000);

        // Update queue visual
        window.dispatchEvent(new CustomEvent('hb_song_selected', { detail: currentSong }));
        // If it was the active projection, update projector
        if (projectionManager.getCurrentIndex() === currentSlideIndex) {
            projectionManager.updateSlide(currentSlideIndex);
        }
    });

    // Enable basic hotkeys inside editor
    editorContent?.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' && e.ctrlKey) {
            e.preventDefault();
            saveBtn?.click();
        }
    });
</script>
