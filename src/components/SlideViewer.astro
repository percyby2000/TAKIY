---
interface Props {
  text: string;
  background?: string;
  index: number;
  label?: string;
  isActive?: boolean;
}

const { text, background, index, label, isActive = false } = Astro.props;
---

<div 
  class={`flex-none w-48 h-full rounded-lg relative overflow-hidden group cursor-pointer transition-all-300 ${
    isActive 
    ? 'border-2 border-brand-cyan glow-cyan ring-4 ring-brand-cyan/10' 
    : 'border border-white/10 hover:border-brand-cyan/50'
  }`}
>
  <div 
    class="absolute inset-0 bg-cover bg-center opacity-30 group-hover:opacity-40 transition-opacity" 
    style={background ? `background-image: url(${background})` : ''}
  ></div>
  <div class="absolute inset-0 bg-gradient-to-t from-black via-transparent to-transparent"></div>
  
  <div class="absolute inset-0 flex items-center justify-center p-4 text-center">
    <span class="text-[10px] font-bold leading-tight line-clamp-3" set:html={text}></span>
  </div>
  
  <div class="absolute bottom-2 left-2 flex items-baseline gap-1">
    <span class={`text-[10px] font-bold ${isActive ? 'text-brand-cyan' : 'text-white/40 group-hover:text-brand-cyan transition-colors'}`}>
      {index.toString().padStart(2, '0')}
    </span>
    {label && <span class="text-[8px] font-medium text-white/40 uppercase">{label}</span>}
  </div>

  {isActive && (
    <div class="absolute top-2 right-2">
        <div class="w-1.5 h-1.5 rounded-full bg-brand-cyan animate-pulse"></div>
    </div>
  )}
</div>
