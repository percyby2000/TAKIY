---
---

<aside class="w-full h-full flex flex-col bg-black/20 backdrop-blur-md">
  <!-- Search -->
  <div class="p-4 border-b border-white/5">
    <div class="relative group">
      <input 
        id="sidebar-search"
        type="text" 
        placeholder="Buscar canciones..." 
        class="w-full bg-white/5 border border-white/10 rounded-lg py-2 px-10 text-sm focus:outline-none focus:border-brand-cyan/50 focus:ring-1 focus:ring-brand-cyan/20 transition-all-300"
      />
      <svg class="absolute left-3 top-2.5 w-4 h-4 text-white/30 group-focus-within:text-brand-cyan transition-colors" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
      </svg>
    </div>
  </div>

  <!-- Tabs -->
  <div class="flex px-4 py-2 gap-1 border-b border-white/5" id="sidebar-tabs">
    <button data-tab="songs" class="flex-1 py-2 text-[10px] font-bold uppercase tracking-widest text-brand-cyan border-b-2 border-brand-cyan transition-all">Canciones</button>
    <button data-tab="bibles" class="flex-1 py-2 text-[10px] font-bold uppercase tracking-widest text-white/40 hover:text-white transition-all">Biblias</button>
    <button data-tab="media" class="flex-1 py-2 text-[10px] font-bold uppercase tracking-widest text-white/40 hover:text-white transition-all">Medios</button>
  </div>

  <!-- List Area -->
  <div class="flex-1 overflow-y-auto p-4 flex flex-col gap-2" id="library-list">
    <!-- Items injected by script -->
  </div>

  <!-- Bottom Actions -->
  <div class="p-4 border-t border-white/5 grid grid-cols-2 gap-3">
    <button id="btn-new-song" class="flex items-center justify-center gap-2 py-2 text-[10px] font-bold uppercase tracking-widest bg-white/5 border border-white/10 rounded-lg hover:bg-brand-cyan hover:text-black hover:border-brand-cyan transition-all-300 transition-colors">
      <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M12 4v16m8-8H4" stroke-width="3" stroke-linecap="round"/></svg>
      NUEVA
    </button>
    <button class="flex items-center justify-center gap-2 py-2 text-[10px] font-bold uppercase tracking-widest bg-white/5 border border-white/10 rounded-lg hover:bg-white/10 transition-all-300">
      <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12" stroke-width="3" stroke-linecap="round"/></svg>
      IMPORTAR
    </button>
  </div>
</aside>

<script>
    import { songManager } from '../utils/songManager';

    const libraryList = document.getElementById('library-list');
    const searchInput = document.getElementById('sidebar-search') as HTMLInputElement;

    function renderSongs(filter = '') {
        const songs = songManager.getSongs();
        if (!libraryList) return;

        libraryList.innerHTML = '';
        
        const filtered = songs.filter((s: any) => 
            s.title.toLowerCase().includes(filter.toLowerCase()) || 
            s.author.toLowerCase().includes(filter.toLowerCase())
        );

        filtered.forEach((song: any) => {
            const item = document.createElement('div');
            item.className = 'p-3 rounded-xl bg-white/5 border border-white/5 hover:border-brand-cyan/30 hover:bg-brand-cyan/5 cursor-pointer transition-all duration-300 group animate-fade-in translate-y-0 hover:-translate-y-1';
            item.innerHTML = `
                <div class="flex justify-between items-start">
                    <div>
                        <h3 class="text-xs font-bold text-white/90 group-hover:text-brand-cyan transition-colors truncate w-40 uppercase tracking-tight">${song.title}</h3>
                        <p class="text-[9px] text-white/40 font-medium">${song.author} • ${song.slides.length} Diap.</p>
                    </div>
                    <span class="text-[8px] bg-white/10 px-1.5 py-0.5 rounded font-bold text-white/60 uppercase tracking-widest">${song.category || 'Himno'}</span>
                </div>
            `;
            
            item.addEventListener('click', () => {
                window.dispatchEvent(new CustomEvent('takiy_song_selected', { detail: song }));
            });
            
            libraryList.appendChild(item);
        });
    }

    renderSongs();

    window.addEventListener('takiy_songs_updated', () => renderSongs(searchInput?.value));

    searchInput?.addEventListener('input', (e) => {
        const target = e.target as HTMLInputElement;
        renderSongs(target.value);
    });

    const tabButtons = document.querySelectorAll('#sidebar-tabs button');
    tabButtons.forEach((btn: any) => {
        btn.addEventListener('click', () => {
            tabButtons.forEach((b: any) => {
                b.classList.remove('text-brand-cyan', 'border-b-2', 'border-brand-cyan');
                b.classList.add('text-white/40');
            });
            btn.classList.add('text-brand-cyan', 'border-b-2', 'border-brand-cyan');
            btn.classList.remove('text-white/40');
            
            if (btn.getAttribute('data-tab') !== 'songs') {
                if (btn.getAttribute('data-tab') === 'bibles') {
                    if (libraryList) {
                        libraryList.innerHTML = `
                            <div class="flex flex-col items-center justify-center py-10 px-4 text-center h-full">
                                <div class="w-16 h-16 rounded-full bg-brand-cyan/10 flex items-center justify-center text-brand-cyan mb-4">
                                    <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path></svg>
                                </div>
                                <h3 class="text-white font-bold mb-2">Explorador de Biblias</h3>
                                <p class="text-xs text-white/50 mb-6">Busca y proyecta versículos con el navegador avanzado gratuito.</p>
                                <button id="btn-open-bible" class="w-full py-3 bg-brand-cyan text-black font-bold uppercase tracking-widest text-[10px] rounded-lg hover:bg-brand-cyan/80 transition-all shadow-[0_0_15px_rgba(34,211,238,0.2)] hover:shadow-[0_0_25px_rgba(34,211,238,0.4)]">
                                    Abrir Navegador
                                </button>
                            </div>
                        `;
                        // Attach event
                        document.getElementById('btn-open-bible')?.addEventListener('click', () => {
                            window.dispatchEvent(new CustomEvent('takiy_open_bible'));
                        });
                        // Autoplay if user prefers direct hit? The user says "al preconar ala biblia me debe mostrar una ventana"
                        // Let's just dispatch it automatically as well!
                        window.dispatchEvent(new CustomEvent('takiy_open_bible'));
                    }
                } else {
                    if (libraryList) libraryList.innerHTML = '<div class="text-center py-20 animate-pulse text-white/10 text-[10px] uppercase font-bold tracking-widest">Cargando...</div>';
                }
            } else {
                renderSongs(searchInput?.value);
            }
        });
    });
</script>
